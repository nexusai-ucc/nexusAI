# ============================================================
# NexusAI — .gitignore
# ============================================================

# ---- Sistema operativo ----
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes

# ---- Editores ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- Variables de entorno y secretos ----
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# ---- Node / Frontend ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.yarn/
.eslintcache
*.tsbuildinfo

# Bundle de React: se commitea por convención Moodle, NO ignorar
# !plugin/local/nexusai/amd/build/

# Source maps (excepto en bundle de prod si los queremos)
*.map

# ---- Moodle ----
# Caché y datos de Moodle
moodledata/
config.php
*.lock

# Archivos generados por Behat
behatdata/

# ---- Backend / Datos ----
# Datos locales del backend (logs, dumps, etc.)
services/api/data/
data/

# Logs
*.log
logs/

# ---- Docker ----
# Mantener docker-compose.yml y Dockerfiles versionados,
# ignorar overrides locales:
docker-compose.override.yml
.docker-data/

# ---- Tests ----
.coverage
coverage/
test-results/
junit.xml

# ---- Builds y artefactos ----
*.tar
*.tar.gz
*.zip
*.tgz

# ---- Misc ----
tmp/
.cache/
*.bak
moodle-src/
