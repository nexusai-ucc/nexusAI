# ============================================================
# NexusAI — Variables de entorno
# ============================================================
#
# Uso:
#   1. cp .env.example .env
#   2. Completar valores marcados con REPLACE_ME y CHANGE_ME_DEV_ONLY
#   3. Generar secretos HMAC con:  openssl rand -hex 32
#
# IMPORTANTE: NUNCA commitear el .env real (está en .gitignore).
# Los valores CHANGE_ME_DEV_ONLY son SOLO para desarrollo local — en producción
# generar passwords fuertes con `openssl rand -base64 24`.
#
# ============================================================

# ----- Entorno de ejecución -----
ENV=development
APP_VERSION=0.1.0

# ============================================================
# LLM Provider — Multi-provider abstracción (ver ADR-003)
# ============================================================
# MVP: Gemini 2.5 Flash (gratuito, tier free de Google)
# Conseguir API key en: https://aistudio.google.com/apikey

LLM_API_KEY=REPLACE_ME_WITH_GEMINI_API_KEY
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.0-flash

# ----- Producción (descomenta y comenta el bloque MVP de arriba) -----
# LLM_API_KEY=sk-REPLACE_ME_WITH_OPENAI_API_KEY
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ============================================================
# Embedding Provider
# ============================================================
# MVP: Gemini Embedding (768 dim, gratuito)

EMBEDDING_API_KEY=REPLACE_ME_WITH_GEMINI_API_KEY
EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSIONS=768

# ----- Producción (descomenta y comenta el bloque MVP) -----
# EMBEDDING_API_KEY=sk-REPLACE_ME
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ============================================================
# Base de datos PostgreSQL + pgvector (ADR-002)
# ============================================================
# Estos valores los usa docker-compose para crear la DB
# Y el backend para conectarse

POSTGRES_USER=nexusai
POSTGRES_PASSWORD=CHANGE_ME_DEV_ONLY
POSTGRES_DB=nexusai
POSTGRES_PORT=5432

# DATABASE_URL — el backend usa esto. En docker-compose se sobrescribe automáticamente
# para apuntar al servicio interno `postgres` en lugar de `localhost`.
DATABASE_URL=postgresql://nexusai:CHANGE_ME_DEV_ONLY@localhost:5432/nexusai

# ============================================================
# Redis — cache + rate limiting + nonce tracking
# ============================================================

REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ============================================================
# Seguridad — HMAC PHP↔Python (ADR-006 a formalizar)
# ============================================================
# Generar con:  openssl rand -hex 32

NEXUSAI_SHARED_SECRET=REPLACE_WITH_HEX_32_FROM_OPENSSL
NEXUSAI_API_KEY=REPLACE_WITH_HEX_32_FROM_OPENSSL
HMAC_REPLAY_WINDOW_SEC=300

# ============================================================
# Rate limiting
# ============================================================

RATE_LIMIT_PER_USER_DAILY=50

# ============================================================
# Backend API
# ============================================================

API_PORT=8001

# ============================================================
# Moodle (solo se usa con profile `full`)
# ============================================================

MOODLE_PORT=8080
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=CHANGE_ME_DEV_ONLY
MOODLE_ADMIN_EMAIL=admin@nexusai.local

# ============================================================
# pgAdmin (solo se usa con profile `tools`)
# ============================================================

PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@nexusai.local
PGADMIN_PASSWORD=CHANGE_ME_DEV_ONLY
